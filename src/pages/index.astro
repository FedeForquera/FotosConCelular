---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Problema from '../components/Problema.astro';
import QueEs from '../components/QueEs.astro';
import Incluye from '../components/Incluye.astro';
import ParaQuien from '../components/ParaQuien.astro';
import { CONFIG } from '../config';
import Preview from '../components/Preview.astro';
import Autor from '../components/Autor.astro';
import FAQ from '../components/islands/FAQ.jsx';
import CTAFinal from '../components/CTAFinal.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <!-- FAQPage schema en <head> via named slot -->
  <script slot="head" type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Necesito un celular único o de última generación?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Las técnicas funcionan con cualquier celular que tenga una cámara decente. Lo importante es la luz, el encuadre y la intención — no el hardware."
        }
      },
      {
        "@type": "Question",
        "name": "¿Tengo que saber de fotografía?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Para nada. El ebook está pensado para emprendedores sin experiencia en fotografía. Todo está explicado desde cero, con ejemplos visuales."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuánto tiempo toma aplicar las técnicas?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Las primeras mejoras las vas a ver en tu próxima sesión fotográfica, que puede durar 30 a 60 minutos. El contenido es directo y aplicable de inmediato."
        }
      },
      {
        "@type": "Question",
        "name": "¿Sirve para cualquier tipo de producto?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí. Está especialmente enfocado en productos físicos: gastronomía, artesanías, indumentaria, accesorios, cosmética y más."
        }
      },
      {
        "@type": "Question",
        "name": "¿Se puede aplicar también para servicios?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "En parte. La sección de Instagram estratégico aplica a cualquier rubro. Para servicios, los conceptos se adaptan al producto visual de tu marca."
        }
      },
      {
        "@type": "Question",
        "name": "¿En qué formato recibo el ebook?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "En PDF digital, con entrega inmediata al confirmar el pago. Podés leerlo desde el celular, tablet o computadora sin ninguna app adicional."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cómo es el proceso de pago y entrega?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "El pago es por transferencia bancaria. Una vez confirmado, recibís el PDF directamente por WhatsApp. Sin demoras ni formularios."
        }
      },
      {
        "@type": "Question",
        "name": "¿Funciona en un departamento pequeño, sin balcón ni luz natural directa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí. Una de las técnicas del ebook está pensada para eso: encontrar y aprovechar cualquier fuente de luz indirecta, incluso en espacios chicos."
        }
      },
      {
        "@type": "Question",
        "name": "¿Puedo consultar dudas después de comprar?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí, podés escribirle directamente a Fede por WhatsApp con cualquier pregunta sobre el contenido del ebook."
        }
      }
    ]
  }
  </script>
  <Nav />
  <main>
    <Hero />
    <Problema />
    <QueEs />
    <Incluye />

    <!-- CTA intermedio -->
    <section class="cta-mid-section">
      <!-- Divisor superior -->
      <div class="cta-mid-divider"></div>

      <div style="max-width:640px;margin:0 auto;text-align:center;position:relative;z-index:1;" class="fade-up">
        <!-- Badge -->
        <div class="cta-mid-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>
          </svg>
          Un solo ebook · Un solo pago
        </div>

        <p style="color:rgba(255,255,255,0.6);font-size:1rem;margin-bottom:10px;font-weight:300;">
          Todo lo que aprendés lo podés aplicar hoy, con el celular que ya tenés.
        </p>
        <p style="color:white;font-family:var(--font-serif);font-size:1.4rem;font-weight:700;margin-bottom:28px;line-height:1.25;">
          Sin estudio. Sin equipos. Sin excusas.
        </p>
        <a href={CONFIG.whatsappUrl} class="btn-cta" target="_blank" rel="noopener noreferrer">
          Quiero el ebook — {CONFIG.precioCompleto}
        </a>
      </div>

      <!-- Divisor inferior -->
      <div class="cta-mid-divider"></div>
    </section>

    <ParaQuien />
    <Preview />
    <Autor />
    <section id="faq" class="faq-section">
      <!-- Decoración fondo -->
      <div class="faq-deco faq-deco-1"></div>
      <div class="faq-deco faq-deco-2"></div>
      <div style="max-width:1100px;margin:0 auto;position:relative;z-index:1;">
        <div class="fade-up" style="margin-bottom:48px;">
          <p class="section-tag">Preguntas frecuentes</p>
          <h2 style="font-size:clamp(2rem,3.5vw,2.8rem);max-width:500px;">
            Todo lo que necesitás<br />saber antes de comprar
          </h2>
        </div>
        <FAQ client:visible />
      </div>
    </section>
    <CTAFinal />
  </main>
  <Footer />
</Layout>

<style>
  /* ── CTA intermedio ── */
  .cta-mid-section {
    padding: 64px 5%;
    background: var(--color-ink);
    position: relative;
    overflow: hidden;
  }

  .cta-mid-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(40,192,180,0.3), transparent);
    margin-bottom: 40px;
  }

  .cta-mid-divider:last-child {
    margin-bottom: 0;
    margin-top: 40px;
  }

  .cta-mid-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(40,192,180,0.12);
    border: 1px solid rgba(40,192,180,0.25);
    color: var(--color-teal);
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 40px;
    margin-bottom: 20px;
  }

  /* ── FAQ ── */
  .faq-section {
    background: var(--color-bg-alt);
    padding: clamp(5rem, 9vw, 7rem) 5%;
    position: relative;
    overflow: hidden;
  }

  .faq-deco {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .faq-deco-1 {
    width: 45vw; height: 45vw;
    top: -15%; right: -8%;
    background: radial-gradient(circle, rgba(40,192,180,0.05) 0%, transparent 65%);
  }

  .faq-deco-2 {
    width: 30vw; height: 30vw;
    bottom: -10%; left: -5%;
    background: radial-gradient(circle, rgba(224,82,40,0.04) 0%, transparent 65%);
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .cta-mid-section {
      padding: 48px 5%;
    }
    .cta-mid-divider {
      margin-bottom: 28px;
    }
    .cta-mid-divider:last-child {
      margin-top: 28px;
    }
    /* CTA intermedio: btn full-width */
    .cta-mid-section .btn-cta {
      width: 100%;
      justify-content: center;
      font-size: .95rem;
    }
    /* Texto del CTA intermedio */
    .cta-mid-section p[style*="font-size:1.4rem"] {
      font-size: 1.2rem !important;
    }
    /* FAQ padding */
    .faq-section {
      padding-left: 5%;
      padding-right: 5%;
    }
  }
</style>
