---
import { CONFIG } from '../config';
---
<nav class="site-nav">
  <div class="nav-inner">

    <!-- Logo -->
    <a href="#hero" class="nav-logo">
      <img src="/images/logo/logofede2.svg" alt="Fede Forquera" class="nav-logo-img" />
    </a>

    <!-- Links desktop -->
    <ul class="nav-links">
      <li><a href="#incluye" class="nav-link">Qué incluye</a></li>
      <li><a href="#para-quien" class="nav-link">Para quién</a></li>
      <li><a href="#autor" class="nav-link">El autor</a></li>
    </ul>

    <!-- CTA desktop (oculto en mobile) -->
    <a href={CONFIG.whatsappUrl} class="nav-cta" target="_blank" rel="noopener noreferrer">
      <span>Comprá el ebook</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>

    <!-- Hamburger mobile -->
    <button class="nav-hamburger" aria-label="Menú" id="nav-hamburger">
      <span></span><span></span><span></span>
    </button>

  </div>

  <!-- Menú desplegable mobile -->
  <div class="nav-mobile-menu" id="nav-mobile-menu">
    <ul class="nav-mobile-links">
      <li><a href="#incluye" class="nav-mobile-link">Qué incluye</a></li>
      <li><a href="#para-quien" class="nav-mobile-link">Para quién</a></li>
      <li><a href="#autor" class="nav-mobile-link">El autor</a></li>
    </ul>
    <a href={CONFIG.whatsappUrl} class="nav-mobile-cta" target="_blank" rel="noopener noreferrer">
      Comprá el ebook →
    </a>
  </div>
</nav>

<script>
  const btn = document.getElementById('nav-hamburger');
  const menu = document.getElementById('nav-mobile-menu');

  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('is-open');
    btn.classList.toggle('is-open', open);
  });

  // Cerrar el menú DESPUÉS de que el scroll arranque
  document.querySelectorAll('.nav-mobile-link').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = (link as HTMLAnchorElement).getAttribute('href');
      if (href && href.startsWith('#')) {
        e.preventDefault();
        // Cerrar menú primero
        menu?.classList.remove('is-open');
        btn?.classList.remove('is-open');
        // Scroll con pequeño delay para que el menú cierre y recalcule el layout
        setTimeout(() => {
          const target = document.querySelector(href);
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }, 50);
      }
    });
  });

  document.querySelector('.nav-mobile-cta')?.addEventListener('click', () => {
    menu?.classList.remove('is-open');
    btn?.classList.remove('is-open');
  });
</script>

<style>
  .site-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(20, 20, 20, 0.96);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(40, 192, 180, 0.18);
  }

  /* Línea teal decorativa en el borde inferior */
  .site-nav::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 2px;
    background: linear-gradient(90deg,
      transparent 0%,
      var(--color-teal) 30%,
      var(--color-orange) 70%,
      transparent 100%);
    opacity: 0.5;
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 5%;
    height: 68px;
    display: flex;
    align-items: center;
    gap: 40px;
  }

  /* Logo */
  .nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .nav-logo-img {
    height: 72px;
    width: auto;
    display: block;
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform-origin: left center;
  }

  .nav-logo:hover .nav-logo-img {
    transform: scale(1.12);
    opacity: 1;
  }

  /* Links desktop */
  .nav-links {
    display: flex;
    list-style: none;
    gap: 8px;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    position: relative;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.65);
    padding: 6px 12px;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px; left: 50%;
    transform: translateX(-50%) scaleX(0);
    width: 20px; height: 2px;
    background: var(--color-teal);
    border-radius: 2px;
    transition: transform 0.25s ease;
  }

  .nav-link:hover { color: white; background: rgba(255,255,255,0.06); }
  .nav-link:hover::after { transform: translateX(-50%) scaleX(1); }

  /* CTA desktop */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-teal);
    color: white;
    padding: 9px 20px;
    border-radius: 40px;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 16px rgba(40, 192, 180, 0.4);
  }
  .nav-cta:hover {
    background: var(--color-teal-dark);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(40, 192, 180, 0.5);
  }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    margin-left: auto;
    flex-shrink: 0;
  }

  .nav-hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: white;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform-origin: center;
  }

  /* Animación X al abrir */
  .nav-hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-hamburger.is-open span:nth-child(2) { opacity: 0; }
  .nav-hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Menú desplegable mobile */
  .nav-mobile-menu {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 16px 5% 24px;
    border-top: 1px solid rgba(255,255,255,0.08);
    background: rgba(20, 20, 20, 0.98);
  }

  .nav-mobile-menu.is-open {
    display: flex;
  }

  .nav-mobile-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 16px;
  }

  .nav-mobile-link {
    display: block;
    padding: 12px 16px;
    font-size: 1rem;
    color: rgba(255,255,255,0.75);
    border-radius: 8px;
    transition: background 0.2s, color 0.2s;
  }

  .nav-mobile-link:hover {
    background: rgba(255,255,255,0.06);
    color: white;
  }

  .nav-mobile-cta {
    display: block;
    text-align: center;
    background: var(--color-teal);
    color: white;
    padding: 14px 20px;
    border-radius: 40px;
    font-size: 1rem;
    font-weight: 600;
    margin-top: 8px;
    transition: background 0.2s;
  }

  .nav-mobile-cta:hover { background: var(--color-teal-dark); }

  /* Mobile */
  @media (max-width: 768px) {
    .nav-inner {
      gap: 16px;
    }

    .nav-links {
      display: none;
    }

    .nav-cta {
      display: none;
    }

    .nav-hamburger {
      display: flex;
    }
  }
</style>
