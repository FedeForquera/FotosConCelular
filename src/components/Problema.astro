---
const pains = [
  {
    n: '01',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`,
    title: 'Las fotos no hacen justicia',
    desc: 'Sacás la foto con el celular y el producto parece barato. El cliente no ve lo que vos ves cuando lo tenés en las manos.'
  },
  {
    n: '02',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
    title: 'La luz siempre sale mal',
    desc: 'Sombras duras, colores raros, brillos quemados. No sabés bien de dónde viene el problema ni cómo arreglarlo.'
  },
  {
    n: '03',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>`,
    title: 'El fondo distrae',
    desc: 'Siempre hay algo que no suma: una pared sucia, un objeto de más, un fondo que compite con el producto.'
  },
  {
    n: '04',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    title: 'Fotos que no venden',
    desc: 'La gente ve la foto pero no pregunta, no compra. Intuís que algo falla en la imagen pero no sabés exactamente qué.'
  }
];
---
<section id="problema" style="padding:clamp(5rem,9vw,7rem) 5%;background:var(--color-ink);color:white;position:relative;overflow:hidden;">

  <!-- Video de fondo -->
  <video
    autoplay muted loop playsinline preload="none"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;"
  >
    <source src="/videos/fondoDeSeccion.mp4" type="video/mp4" />
  </video>
  <!-- Overlay oscuro sobre el video -->
  <div style="position:absolute;inset:0;background:rgba(8,18,16,0.88);z-index:1;"></div>

  <!-- Decoración teal glow -->
  <div style="position:absolute;left:-10%;top:-20%;width:50vw;height:50vw;
    background:radial-gradient(circle,rgba(40,192,180,0.08) 0%,transparent 60%);
    border-radius:50%;pointer-events:none;z-index:1;"></div>

  <div style="max-width:1100px;margin:0 auto;position:relative;z-index:2;">

    <div class="fade-up" style="margin-bottom:56px;">
      <p class="section-tag" style="color:var(--color-teal);">El problema</p>
      <h2 style="font-family:var(--font-serif);font-size:clamp(2rem,3.5vw,2.8rem);
        font-weight:700;line-height:1.15;max-width:680px;">
        Tus productos son buenos.<br/>
        <em style="color:var(--color-teal);font-style:italic;">
          Las fotos no siempre los muestran así.
        </em>
      </h2>
    </div>

    <div class="stagger fade-up pains-grid" style="margin-bottom:56px;">
      {pains.map(p => (
        <div class="pain-card">
          <!-- Número marca de agua -->
          <div class="pain-num-bg">{p.n}</div>

          <!-- Icono SVG -->
          <div class="pain-icon" set:html={p.icon}></div>

          <h3 class="pain-title">{p.title}</h3>
          <p class="pain-desc">{p.desc}</p>
        </div>
      ))}
    </div>

    <div class="fade-up problema-conclusion">
      <div class="conclusion-line"></div>
      <p>
        Pero no es culpa de tu celular.<br/>
        <strong style="color:var(--color-teal);font-weight:500;">
          Es cuestión de saber exactamente cómo usarlo.
        </strong>
      </p>
    </div>

  </div>
</section>

<style>
  .pains-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .pain-card {
    position: relative;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    padding: 32px 28px;
    border-radius: 14px;
    overflow: hidden;
    backdrop-filter: blur(8px);
    transition: border-color .25s, background .25s;
  }

  .pain-card:hover {
    border-color: rgba(40,192,180,0.35);
    background: rgba(40,192,180,0.06);
  }

  /* Número marca de agua */
  .pain-num-bg {
    position: absolute;
    top: -16px;
    right: 16px;
    font-family: var(--font-serif);
    font-size: 7rem;
    font-weight: 900;
    color: rgba(255,255,255,0.03);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  /* Icono SVG */
  .pain-icon {
    width: 48px;
    height: 48px;
    background: rgba(40,192,180,0.12);
    border: 1px solid rgba(40,192,180,0.2);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
    color: var(--color-teal);
    flex-shrink: 0;
  }

  .pain-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .pain-desc {
    font-size: .875rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
  }

  /* Conclusión */
  .problema-conclusion {
    display: flex;
    align-items: center;
    gap: 24px;
    font-size: 1.05rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
  }

  .conclusion-line {
    width: 3px;
    height: 56px;
    background: linear-gradient(180deg, var(--color-teal), transparent);
    border-radius: 2px;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .pains-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .pain-card {
      padding: 24px 20px;
    }
    .problema-conclusion {
      font-size: .95rem;
      gap: 16px;
    }
    .conclusion-line {
      height: 40px;
    }
  }
</style>
