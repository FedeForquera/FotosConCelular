---
const si = [
  'Hacés productos artesanales, gastronómicos o de diseño',
  'Vendés por Instagram, WhatsApp o tienda online',
  'Querés fotos más profesionales sin comprar equipos',
  'Sentís que tus fotos no muestran el valor real de lo que hacés',
  'Tenés poco tiempo y querés resultados rápidos y concretos',
];
const no = [
  'Ya sos fotógrafo profesional con experiencia en producto',
  'Buscás un curso técnico profundo sobre cámaras y óptica',
  'Querés aprender edición avanzada en Lightroom o Photoshop',
  'Necesitás un estudio profesional o producción a gran escala',
];
---
<section id="para-quien" style="padding:clamp(5rem,9vw,7rem) 5%;background:var(--color-bg-alt);position:relative;overflow:hidden;">

  <!-- Decoración fondo -->
  <div style="position:absolute;left:-8%;top:-10%;width:45vw;height:45vw;
    background:radial-gradient(circle,rgba(40,192,180,0.06) 0%,transparent 65%);
    border-radius:50%;pointer-events:none;"></div>
  <div style="position:absolute;right:-5%;bottom:-10%;width:30vw;height:30vw;
    background:radial-gradient(circle,rgba(224,82,40,0.05) 0%,transparent 65%);
    border-radius:50%;pointer-events:none;"></div>

  <div style="max-width:1100px;margin:0 auto;position:relative;z-index:1;">

    <div class="fade-up" style="margin-bottom:56px;">
      <p class="section-tag">Para quién es</p>
      <h2 style="font-size:clamp(2rem,3.5vw,2.8rem);">
        ¿Este ebook<br/>es para vos?
      </h2>
    </div>

    <div class="stagger fade-up pq-grid">

      <!-- Card SÍ -->
      <div class="pq-card pq-card-yes">
        <div class="pq-card-header">
          <div class="pq-icon pq-icon-yes">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <div>
            <div class="pq-card-accent pq-card-accent-yes"></div>
            <h3 class="pq-card-title pq-title-yes">Es para vos si...</h3>
          </div>
        </div>
        <ul class="pq-list">
          {si.map(item => (
            <li class="pq-item">
              <div class="pq-dot pq-dot-yes">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Card NO -->
      <div class="pq-card pq-card-no">
        <div class="pq-card-header">
          <div class="pq-icon pq-icon-no">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </div>
          <div>
            <div class="pq-card-accent pq-card-accent-no"></div>
            <h3 class="pq-card-title pq-title-no">No es para vos si...</h3>
          </div>
        </div>
        <ul class="pq-list">
          {no.map(item => (
            <li class="pq-item">
              <div class="pq-dot pq-dot-no">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
              </div>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>

<style>
  .pq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .pq-card {
    background: white;
    border-radius: 16px;
    padding: 32px 28px;
    border: 1.5px solid rgba(0,0,0,0.05);
    transition: box-shadow .25s, transform .25s, border-color .25s;
    display: flex;
    flex-direction: column;
  }

  .pq-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.09);
  }

  .pq-card-yes:hover { border-color: rgba(40,192,180,0.25); }
  .pq-card-no:hover  { border-color: rgba(224,82,40,0.18); }

  /* Barra acento — debajo del ícono, arriba del título */
  .pq-card-accent {
    height: 3px;
    border-radius: 3px;
    margin-bottom: 8px;
    width: 32px;
  }

  .pq-card-accent-yes {
    background: var(--color-teal);
  }

  .pq-card-accent-no {
    background: var(--color-orange);
  }

  /* Header */
  .pq-card-header {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin-bottom: 24px;
  }

  .pq-icon {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .pq-icon-yes {
    background: var(--color-teal-light);
    color: var(--color-teal);
  }

  .pq-icon-no {
    background: #fde8e8;
    color: var(--color-orange);
  }

  .pq-card-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .pq-title-yes { color: var(--color-ink); }
  .pq-title-no  { color: var(--color-ink); }

  /* Lista */
  .pq-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pq-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: .9rem;
    line-height: 1.55;
    color: var(--color-ink-2);
  }

  .pq-dot {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .pq-dot-yes {
    background: var(--color-teal-light);
    color: var(--color-teal);
  }

  .pq-dot-no {
    background: #fde8e8;
    color: var(--color-orange);
  }

  @media (max-width: 768px) {
    .pq-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .pq-card {
      padding: 24px 20px;
    }
    .pq-item {
      font-size: .875rem;
    }
  }
</style>
