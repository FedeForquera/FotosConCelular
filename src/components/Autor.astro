---
import { CONFIG } from '../config';

const bioBlocks = [
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    label: 'Pasión',
    text: 'Hace más de cuatro años vivo de la fotografía y el contenido audiovisual. Me dedico a gastronomía, productos y cobertura de eventos.'
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    label: 'Origen',
    text: 'Nací en Trelew-Chubut, crecí rodeado de naturaleza y silencio. Hoy vivo en Buenos Aires, apostando todo a mi proyecto y mi forma de vivir.'
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    label: 'Camino',
    text: 'Estudié Contador Público, dejé la carrera en tercer año para hacerme caso a mí mismo. La autenticidad siempre ganó.'
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    label: 'Propósito',
    text: 'Trabajo con personas comprometidas y marcas que aman lo que hacen. Mi meta: crear contenido con alma, que no solo muestre sino que cuente algo.'
  },
];
---
<section id="autor" style="padding:clamp(5rem,9vw,7rem) 5%;background:var(--color-bg);position:relative;overflow:hidden;">

  <!-- Decoración fondo -->
  <div style="position:absolute;right:-8%;top:-15%;width:50vw;height:50vw;
    background:radial-gradient(circle,rgba(40,192,180,0.06) 0%,transparent 65%);
    border-radius:50%;pointer-events:none;"></div>

  <!-- Foto de fondo difuminada lado derecho -->
  <div class="autor-bg-foto" aria-hidden="true">
    <img src="/images/about/fedefot.jpg" alt="" />
  </div>

  <div style="max-width:1100px;margin:0 auto;position:relative;z-index:1;">

    <div class="fade-up" style="margin-bottom:56px;">
      <p class="section-tag">El autor</p>
      <h2 style="font-size:clamp(2rem,3.5vw,2.8rem);">
        ¿Por qué Fede<br/>sabe de esto?
      </h2>
    </div>

    <div class="fade-up autor-grid">

      <!-- Foto columna -->
      <div class="autor-foto-col">

        <!-- Foto con marco teal -->
        <div class="autor-foto-frame">
          <img
            src="/images/about/fedeabout.jpg"
            alt="Fede Forquera, fotógrafo y filmmaker publicitario de Buenos Aires"
            class="autor-foto"
            loading="lazy"
            width="280"
            height="340"
          />
          <!-- Marco decorativo teal (dentro del frame, no desborda) -->
          <div class="foto-marco" aria-hidden="true"></div>
        </div>

        <!-- Badge nombre/rol -->
        <div class="autor-badge">
          <div class="autor-badge-dot"></div>
          <div>
            <div class="autor-badge-name">{CONFIG.autorNombre}</div>
            <div class="autor-badge-role">{CONFIG.autorRol}</div>
          </div>
        </div>

        <!-- Instagram link -->
        <a href={CONFIG.instagramUrl} target="_blank" rel="noopener noreferrer"
          class="autor-ig-btn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
          {CONFIG.instagramHandle}
        </a>
      </div>

      <!-- Bio columna -->
      <div class="autor-bio-col">

        <div class="autor-intro">
          <p>Hola, soy <strong>Fede Forquera</strong> — fotógrafo y filmmaker publicitario. Este ebook nació de años de trabajo real con emprendedores que necesitaban mejorar sus fotos sin equipos caros.</p>
        </div>

        <div class="autor-blocks">
          {bioBlocks.map(b => (
            <div class="autor-block">
              <div class="autor-block-icon" set:html={b.icon}></div>
              <div>
                <div class="autor-block-label">{b.label}</div>
                <p class="autor-block-text">{b.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Grid principal ── */
  .autor-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 56px;
    align-items: start;
  }

  /* ── Foto columna ── */
  .autor-foto-col {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 16px;
  }

  /* Frame de la foto — contiene todo */
  .autor-foto-frame {
    position: relative;
    border-radius: 18px;
    overflow: visible; /* necesario para el marco decorativo */
  }

  .autor-foto {
    width: 100%;
    height: 340px;
    border-radius: 18px;
    object-fit: cover;
    object-position: center top;
    box-shadow: 0 16px 48px rgba(0,0,0,0.14);
    display: block;
    position: relative;
    z-index: 1;
  }

  /* Marco teal decorativo — borde exterior simple sin overflow problemático */
  .foto-marco {
    position: absolute;
    inset: 0;
    border-radius: 18px;
    border: 2px solid rgba(40,192,180,0.35);
    pointer-events: none;
    z-index: 2;
    /* Pequeño offset visual con box-shadow externo en lugar de insets negativos */
    box-shadow: 6px 6px 0 0 rgba(40,192,180,0.12);
  }

  /* Badge */
  .autor-badge {
    display: flex;
    align-items: center;
    gap: 12px;
    background: white;
    border: 1px solid rgba(40,192,180,0.15);
    padding: 12px 14px;
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.07);
  }

  .autor-badge-dot {
    width: 10px;
    height: 10px;
    background: var(--color-teal);
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(40,192,180,0.15);
  }

  .autor-badge-name {
    font-family: var(--font-serif);
    font-size: .92rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-ink);
  }

  .autor-badge-role {
    font-size: .72rem;
    color: var(--color-teal);
    font-weight: 500;
    margin-top: 2px;
  }

  /* Instagram button */
  .autor-ig-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: white;
    border: 1px solid rgba(0,0,0,0.08);
    padding: 10px 16px;
    border-radius: 40px;
    font-size: .82rem;
    font-weight: 500;
    color: var(--color-ink);
    transition: border-color .2s, box-shadow .2s;
    align-self: flex-start;
  }

  .autor-ig-btn:hover {
    border-color: var(--color-teal);
    box-shadow: 0 4px 16px rgba(40,192,180,0.12);
  }

  /* ── Bio columna ── */
  .autor-bio-col {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  /* Intro */
  .autor-intro {
    padding-left: 20px;
    border-left: 3px solid var(--color-teal);
  }

  .autor-intro p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-ink-2);
    font-weight: 300;
  }

  .autor-intro strong {
    font-weight: 600;
    color: var(--color-ink);
  }

  /* Bloques bio */
  .autor-blocks {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .autor-block {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 18px;
    background: white;
    border-radius: 12px;
    border: 1px solid rgba(0,0,0,0.05);
    transition: border-color .2s, box-shadow .2s;
  }

  .autor-block:hover {
    border-color: rgba(40,192,180,0.2);
    box-shadow: 0 4px 16px rgba(0,0,0,0.05);
  }

  .autor-block-icon {
    width: 36px;
    height: 36px;
    background: var(--color-teal-light);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-teal);
    flex-shrink: 0;
  }

  .autor-block-label {
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--color-teal);
    margin-bottom: 3px;
  }

  .autor-block-text {
    font-size: .86rem;
    color: var(--color-ink-2);
    line-height: 1.65;
    font-weight: 300;
    margin: 0;
  }

  /* ── Foto de fondo difuminada ── */
  .autor-bg-foto {
    position: absolute;
    right: 0;
    top: 0;
    width: 45%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    /* Gradiente: desvanece por la izquierda, arriba y abajo */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      rgba(0,0,0,0.4) 18%,
      rgba(0,0,0,0.8) 50%,
      black 100%
    ), linear-gradient(
      to bottom,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
    -webkit-mask-composite: destination-in;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      rgba(0,0,0,0.4) 18%,
      rgba(0,0,0,0.8) 50%,
      black 100%
    ), linear-gradient(
      to bottom,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
    mask-composite: intersect;
  }

  .autor-bg-foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    opacity: 0.22;
    display: block;
    filter: grayscale(20%);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .autor-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .autor-foto-col {
      align-items: center;
    }
    .autor-foto-frame {
      width: 300px;
    }
    .autor-foto {
      height: 420px;
    }
    .autor-badge {
      width: 300px;
    }
    .autor-ig-btn {
      align-self: center;
    }
  }

  @media (max-width: 768px) {
    .autor-grid {
      gap: 28px;
    }
    .autor-block {
      padding: 12px 14px;
      gap: 12px;
    }
    .autor-block-text {
      font-size: .83rem;
    }
    .autor-intro p {
      font-size: .97rem;
    }
  }

  @media (max-width: 480px) {
    .autor-foto-frame {
      width: 100%;
    }
    .autor-foto {
      height: 420px;
    }
    .autor-badge {
      width: 100%;
    }
  }
</style>
