---
const caps = [
  { n:'01', title:'Mentalidad visual', desc:'Cómo pensar la fotografía con intención antes de tocar el celular.' },
  { n:'02', title:'Luz natural bien usada', desc:'La técnica de la ventana: cómo conseguir luz perfecta sin equipos.' },
  { n:'03', title:'Escenografía simple', desc:'Fondos, props y superficies que suman sin robarle protagonismo al producto.' },
  { n:'04', title:'5 tipos de fotos', desc:'Las imágenes que realmente ayudan a vender: catálogo, contexto, uso, detalle e identidad.' },
  { n:'05', title:'Mini módulo e-commerce', desc:'Fotos para tienda online: encuadres, cantidad mínima y coherencia visual.' },
  { n:'06', title:'Instagram estratégico', desc:'Cómo sacar 7 piezas de contenido de una sola sesión fotográfica.' },
];
---
<section id="incluye" style="padding:clamp(5rem,9vw,7rem) 5%;background:white;position:relative;overflow:hidden;">

  <!-- Decoración de fondo -->
  <div style="position:absolute;right:-8%;bottom:-10%;width:40vw;height:40vw;
    background:radial-gradient(circle,rgba(40,192,180,0.05) 0%,transparent 65%);
    border-radius:50%;pointer-events:none;"></div>

  <div style="max-width:1100px;margin:0 auto;position:relative;z-index:1;">

    <div class="fade-up" style="display:flex;justify-content:space-between;
      align-items:flex-end;margin-bottom:56px;flex-wrap:wrap;gap:20px;">
      <div>
        <p class="section-tag">Contenido</p>
        <h2 style="font-size:clamp(2rem,3.5vw,2.8rem);">
          6 capítulos para dominar<br/>la foto de producto
        </h2>
      </div>
      <p style="font-size:.875rem;color:var(--color-muted);
        max-width:260px;text-align:right;line-height:1.65;">
        Cada capítulo es concreto, visual y aplicable desde el primer momento.
      </p>
    </div>

    <div class="stagger fade-up caps-grid" style="margin-bottom:32px;">
      {caps.map(c => (
        <div class="cap-card">
          <!-- Número marca de agua -->
          <div class="cap-num-bg">{c.n}</div>
          <!-- Barra acento lateral -->
          <div class="cap-accent-bar"></div>
          <!-- Número pequeño visible -->
          <div class="cap-num-label">{c.n}</div>
          <h3 class="cap-title">{c.title}</h3>
          <p class="cap-desc">{c.desc}</p>
        </div>
      ))}
    </div>

    <!-- Bonus -->
    <div class="fade-up bonus-bar">
      <div class="bonus-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <div>
        <h4 style="font-family:var(--font-serif);font-size:1.05rem;font-weight:700;margin-bottom:4px;">
          Bonus — Checklist antes de cada sesión
        </h4>
        <p style="font-size:.85rem;opacity:.85;line-height:1.6;">
          5 preguntas que te aseguran que cada foto que sacás tiene intención y comunica.
        </p>
      </div>
    </div>

    <!-- Vista previa del índice -->
    <div class="fade-up" style="margin-top:48px;text-align:center;">
      <p style="font-size:.75rem;color:var(--color-muted);margin-bottom:14px;
        text-transform:uppercase;letter-spacing:.1em;font-weight:600;">
        Vista previa del contenido
      </p>
      <img
        src="/images/ebook/indicefotos.PNG"
        alt="Índice del ebook Fotos con Celular que Venden — 6 capítulos de fotografía de producto para emprendedores"
        loading="lazy"
        width="600"
        style="max-width:100%;border-radius:12px;
          box-shadow:0 8px 40px rgba(0,0,0,0.10);margin:0 auto;"
      />
    </div>

  </div>
</section>

<style>
  .caps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .cap-card {
    position: relative;
    padding: 28px 24px 24px 28px;
    border-radius: 14px;
    background: var(--color-bg);
    border: 1.5px solid rgba(40,192,180,0.08);
    overflow: hidden;
    transition: border-color .25s, box-shadow .25s, transform .25s, background .25s;
    cursor: default;
  }

  .cap-card:hover {
    border-color: var(--color-teal);
    background: white;
    box-shadow: 0 8px 32px rgba(40,192,180,0.12);
    transform: translateY(-3px);
  }

  /* Número gigante marca de agua */
  .cap-num-bg {
    position: absolute;
    top: -12px;
    right: 12px;
    font-family: var(--font-serif);
    font-size: 6rem;
    font-weight: 900;
    color: rgba(40,192,180,0.06);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    transition: color .25s;
  }

  .cap-card:hover .cap-num-bg {
    color: rgba(40,192,180,0.1);
  }

  /* Barra acento lateral */
  .cap-accent-bar {
    position: absolute;
    left: 0;
    top: 20%;
    bottom: 20%;
    width: 3px;
    background: linear-gradient(180deg, var(--color-teal), transparent);
    border-radius: 0 2px 2px 0;
    opacity: 0;
    transition: opacity .25s;
  }

  .cap-card:hover .cap-accent-bar {
    opacity: 1;
  }

  /* Número pequeño */
  .cap-num-label {
    font-family: var(--font-serif);
    font-size: .75rem;
    font-weight: 700;
    color: var(--color-teal);
    letter-spacing: .08em;
    margin-bottom: 10px;
    position: relative;
    z-index: 1;
  }

  .cap-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 10px;
    position: relative;
    z-index: 1;
    line-height: 1.3;
  }

  .cap-desc {
    font-size: .82rem;
    color: var(--color-muted);
    line-height: 1.65;
    position: relative;
    z-index: 1;
  }

  /* Bonus bar */
  .bonus-bar {
    background: linear-gradient(135deg, var(--color-teal) 0%, var(--color-teal-dark) 100%);
    color: white;
    padding: 22px 28px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    gap: 20px;
    box-shadow: 0 8px 32px rgba(40,192,180,0.3);
  }

  .bonus-icon {
    width: 44px;
    height: 44px;
    background: rgba(255,255,255,0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 1px solid rgba(255,255,255,0.2);
  }

  @media (max-width: 900px) {
    .caps-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    /* Header: apilar verticalmente */
    #incluye div[style*="justify-content:space-between"] {
      flex-direction: column !important;
      align-items: flex-start !important;
      gap: 12px !important;
      margin-bottom: 36px !important;
    }
    #incluye div[style*="justify-content:space-between"] p {
      text-align: left !important;
      max-width: 100% !important;
    }
    .caps-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .cap-card {
      padding: 22px 20px 20px 22px;
    }
    /* Bonus bar: apilar en mobile */
    .bonus-bar {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
      padding: 20px 20px;
    }
  }
</style>
