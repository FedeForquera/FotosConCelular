---
import { CONFIG } from '../config';
const features = [
  { icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`, text: '~50 páginas 100% prácticas' },
  { icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`, text: 'Técnicas con cualquier celular' },
  { icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/></svg>`, text: 'Luz, escenografía y redes' },
  { icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`, text: 'Checklist descargable' },
];
---
<section id="cta-final" class="cta-section">

  <!-- Fondo con degradado diagonal -->
  <div class="cta-bg" aria-hidden="true"></div>
  <!-- Decoración de círculos -->
  <div class="cta-circle cta-circle-1" aria-hidden="true"></div>
  <div class="cta-circle cta-circle-2" aria-hidden="true"></div>

  <div style="max-width:720px;margin:0 auto;text-align:center;position:relative;z-index:1;">

    <p class="section-tag fade-up" style="color:rgba(255,255,255,0.6);">Tu turno</p>

    <!-- Social proof -->
    <div class="fade-up cta-social-proof">
      <div class="cta-stars">
        {[1,2,3,4,5].map(() => (
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        ))}
      </div>
      <span>🚀 Lanzamiento — Sábado 25 de abril</span>
    </div>

    <h2 class="fade-up cta-title">
      Empezá a vender con<br/>
      <em>fotos que impactan</em>
    </h2>

    <p class="fade-up" style="font-size:1.05rem;color:rgba(255,255,255,0.75);
      margin-bottom:40px;font-weight:300;line-height:1.75;">
      Un solo ebook. Un solo pago. Fotos que trabajan para vos.
    </p>

    <!-- Features pills -->
    <div class="stagger fade-up cta-features">
      {features.map(f => (
        <div class="cta-pill">
          <span class="cta-pill-icon" set:html={f.icon}></span>
          {f.text}
        </div>
      ))}
    </div>

    <!-- Precio -->
    <div class="fade-up cta-price-block">
      <div class="cta-price-label">Precio especial de lanzamiento</div>
      <div class="cta-price">
        <span class="cta-currency">$</span>
        <span class="cta-amount">20.000</span>
        <span class="cta-currency cta-currency-right">ARS</span>
      </div>
      <div class="cta-price-sub">Pago único — acceso inmediato al PDF</div>
    </div>

    <!-- Botón CTA -->
    <a href={CONFIG.whatsappUrl} class="cta-btn fade-up" target="_blank" rel="noopener noreferrer">
      Quiero mi ebook →
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </a>

    <p class="fade-up" style="margin-top:16px;font-size:.78rem;color:rgba(255,255,255,0.45);
      display:flex;align-items:center;justify-content:center;gap:6px;">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      Respondemos por WhatsApp en minutos · Pago por transferencia
    </p>

  </div>
</section>

<style>
  .cta-section {
    padding: clamp(5rem, 9vw, 7rem) 5%;
    position: relative;
    overflow: hidden;
    color: white;
  }

  /* Fondo degradado diagonal */
  .cta-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-teal-dark) 0%, var(--color-teal) 45%, var(--color-teal-dark) 100%);
    z-index: 0;
  }

  /* Círculos decorativos */
  .cta-circle {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }

  .cta-circle-1 {
    width: 500px;
    height: 500px;
    top: -200px;
    right: -100px;
    background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, transparent 60%);
  }

  .cta-circle-2 {
    width: 400px;
    height: 400px;
    bottom: -150px;
    left: -80px;
    background: radial-gradient(circle, rgba(0,0,0,0.1) 0%, transparent 65%);
  }

  /* Social proof */
  .cta-social-proof {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.18);
    padding: 8px 20px;
    border-radius: 40px;
    font-size: .82rem;
    margin-bottom: 28px;
  }

  .cta-stars {
    display: flex;
    gap: 2px;
    color: var(--color-orange);
  }

  /* Título */
  .cta-title {
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    color: white;
    margin-bottom: 20px;
    line-height: 1.1;
  }

  .cta-title em {
    font-style: italic;
    opacity: 0.9;
  }

  /* Features pills */
  .cta-features {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-bottom: 44px;
  }

  .cta-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.18);
    padding: 7px 18px;
    border-radius: 40px;
    font-size: .82rem;
  }

  .cta-pill-icon {
    display: flex;
    align-items: center;
    opacity: 0.85;
  }

  /* Bloque precio */
  .cta-price-block {
    margin-bottom: 36px;
  }

  .cta-price-label {
    display: inline-block;
    background: var(--color-orange);
    color: #5a3800;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 40px;
    margin-bottom: 12px;
  }

  .cta-price {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 4px;
    line-height: 1;
    margin-bottom: 8px;
  }

  .cta-currency {
    font-family: var(--font-sans);
    font-size: 1.8rem;
    font-weight: 400;
    opacity: 0.8;
    margin-top: 8px;
  }

  .cta-currency-right {
    font-size: 1.1rem;
    margin-top: 16px;
    letter-spacing: .05em;
  }

  .cta-amount {
    font-family: var(--font-serif);
    font-size: 5rem;
    font-weight: 900;
    letter-spacing: -0.02em;
  }

  .cta-price-sub {
    font-size: .85rem;
    color: rgba(255,255,255,0.6);
  }

  /* Botón */
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: white;
    color: var(--color-teal-dark);
    font-weight: 700;
    padding: 18px 52px;
    border-radius: 50px;
    font-size: 1.1rem;
    font-family: var(--font-serif);
    transition: transform .2s, box-shadow .2s, background .2s;
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    letter-spacing: -0.01em;
  }

  .cta-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 40px rgba(0,0,0,0.25);
    background: #f0faf8;
  }

  @media (max-width: 768px) {
    .cta-social-proof {
      font-size: .78rem;
      padding: 7px 14px;
    }
    .cta-features {
      gap: 8px;
      margin-bottom: 32px;
    }
    .cta-pill {
      font-size: .78rem;
      padding: 6px 14px;
    }
    .cta-price-block {
      margin-bottom: 28px;
    }
    /* Botón full-width en mobile */
    .cta-btn {
      width: 100%;
      justify-content: center;
      padding: 17px 24px;
      font-size: 1rem;
    }
  }

  @media (max-width: 480px) {
    .cta-amount { font-size: 3.8rem; }
  }
</style>
